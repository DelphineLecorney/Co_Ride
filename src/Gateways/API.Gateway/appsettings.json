{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "Services": {
    "Identity": "https://localhost:7010",
    "Trip": "https://localhost:7001",
    "Booking": "https://localhost:7002",
    "Notification": "https://localhost:7003"
  },

  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "trip-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/trips/{**catch-all}"
        }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/bookings/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "https://localhost:7010"
          }
        }
      },
      "trip-cluster": {
        "Destinations": {
          "trip-destination": {
            "Address": "https://localhost:7001"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "booking-destination": {
            "Address": "https://localhost:7002"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "https://localhost:7003"
          }
        }
      }
    }
  },

  "Seq": {
    "ServerUrl": "http://localhost:5341"
  }
}
