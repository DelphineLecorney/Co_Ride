# ===========================
# DATABASES
# ===========================

# PostgreSQL (Trip Service - Marten Event Store)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=TripDB
POSTGRES_PORT=5432

# SQL Server (Identity & Booking Services)
SQLSERVER_SA_PASSWORD=P@ssw0rd123!
SQLSERVER_PORT=1433

# MongoDB (Notification Service)
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=admin123
MONGODB_DATABASE=NotificationDB
MONGODB_PORT=27017

# ===========================
# MESSAGING & CACHE
# ===========================

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Redis
REDIS_PORT=6379

# ===========================
# LOGGING
# ===========================

# Seq
SEQ_PORT=5341

# ===========================
# SERVICES PORTS
# ===========================

API_GATEWAY_PORT=5000
IDENTITY_API_PORT=5001
TRIP_API_PORT=5002
BOOKING_API_PORT=5003
NOTIFICATION_API_PORT=5004
BLAZOR_CLIENT_PORT=5005

# ===========================
# JWT CONFIGURATION
# ===========================

JWT_SECRET_KEY=YourSuperSecretKeyForJWTMustBe32CharsMin
JWT_ISSUER=CovoiturageIdentityService
JWT_AUDIENCE=CovoiturageAPI
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# ===========================
# ASPNETCORE ENVIRONMENT
# ===========================

ASPNETCORE_ENVIRONMENT=Development

# ===========================
# CORS (pour Blazor WASM)
# ===========================

CORS_ALLOWED_ORIGINS=http://localhost:5005,https://localhost:5005

# ===========================
# EXTERNAL SERVICES (optionnel)
# ===========================

# Email Service (exemple : SendGrid)
# SENDGRID_API_KEY=your-api-key

# SMS Service (exemple : Twilio)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
